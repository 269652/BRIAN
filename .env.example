# Copy to `.env` and fill in. `.env` is gitignored — never commit real tokens.
# Used by scripts/vast_deploy.sh.

# Vast.ai API key — Account → API Keys on vast.ai
# (alias accepted: VAST_AI)
VAST_API_KEY=

# GitHub personal-access-token with Contents:read/write on the BRIAN repo
# (used by the instances to clone + push checkpoints to Git LFS)
# (aliases accepted: GITHUB_PAT, GH_TOKEN)
GITHUB=

# Optional: HuggingFace token (faster dataset downloads, higher rate limits)
HF_TOKEN=

# ── Optional run config (defaults shown) ────────────────────────────────
PRESET=large
STEPS=100000
BATCH=32
GRAD_ACCUM=1
SAVE_EVERY=1000
LOG_EVERY=20
# Docker image for the instances (PyTorch + CUDA 12.x):
VAST_IMAGE=pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime
# Min disk per instance (GB):
VAST_DISK=60
# GPU filter for the offer search:
VAST_GPU_NAME=A100
