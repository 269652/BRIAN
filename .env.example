# Copy to `.env` and fill in. `.env` is gitignored — never commit real tokens.
# Used by scripts/vast_deploy.sh.

# Vast.ai API key — Account → API Keys on vast.ai
# (alias accepted: VAST_AI)
VAST_API_KEY=

# GitHub personal-access-token with Contents:read/write on the BRIAN repo
# (used by the instances to clone + push checkpoints to Git LFS)
# (aliases accepted: GITHUB_PAT, GH_TOKEN)
GITHUB=

# HuggingFace write-token for checkpoint pushes.
#
# REQUIRED when brian.toml [defaults] push_backend = "hf" (the
# 2026-06-15 default after the LFS push-hang at step 500). The token
# resolution chain is:
#   1. explicit `token=...` arg to push_checkpoint_to_hf (never used in
#      production)
#   2. HF_TOKEN env var (← this file feeds the local one; ONSTART feeds
#      the on-box one)
#   3. cached ~/.huggingface/token (from `huggingface-cli login`)
#   4. skip the push cleanly with a warning (no crash)
#
# Get yours at: https://huggingface.co/settings/tokens
# Scope: needs `write` access to the repo named in brian.toml
# [defaults] hf_repo_id (default: moritzroessler/BRIAN).
#
# Set push_backend = "lfs" or "none" in brian.toml to skip HF auth
# entirely.
HF_TOKEN=

# ── Optional run config (defaults shown) ────────────────────────────────
PRESET=large
STEPS=100000
BATCH=32
GRAD_ACCUM=1
SAVE_EVERY=1000
LOG_EVERY=20
# Docker image for the instances (PyTorch + CUDA 12.x):
VAST_IMAGE=pytorch/pytorch:2.3.0-cuda12.1-cudnn8-runtime
# Min disk per instance (GB):
VAST_DISK=60
# GPU filter for the offer search (vast query fragment; `~` is NOT a valid
# operator — use `in [...]` or `=`):
VAST_GPU_QUERY=gpu_name in [A100_SXM4,A100_PCIE,A100_SXM,A100X]
