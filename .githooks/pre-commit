#!/usr/bin/env bash
# .githooks/pre-commit — auto-render README.md from README.template.md
#
# Activated by running once (from repo root):
#   git config core.hooksPath .githooks
#
# Works on both Windows (Git Bash) and Linux/macOS.

set -e

REPO="$(git rev-parse --show-toplevel)"

# Find Python in venv
if [ -f "$REPO/.venv/Scripts/python.exe" ]; then
  PYTHON="$REPO/.venv/Scripts/python.exe"
elif [ -f "$REPO/.venv/bin/python" ]; then
  PYTHON="$REPO/.venv/bin/python"
else
  echo "[pre-commit] .venv not found — skipping README render" >&2
  exit 0
fi

# Use brian CLI to render README
"$PYTHON" -m neuroslm.cli update-readme

# Stage README.md if it changed
if ! git diff --quiet README.md 2>/dev/null; then
  git add README.md
  echo "[pre-commit] README.md staged"
fi
