# -*- coding: utf-8 -*-
# Shared equation library — reusable across every BRIAN architecture.
#
# Resolution: importable as `@brian/equations` from any arch.neuro.
# Anchored at <repo>/architectures/lib/equations.neuro by the @brian/
# prefix in neuroslm/dsl/multifile.py:PathResolver.
#
# Layout convention:
#
#   architectures/
#       lib/
#           equations.neuro            ← this file (declarations only)
#           features/
#               <name>.neuro           ← one file per toggleable mechanism
#                                       declares: feature <name> { ... }
#                                       imports: the equation it implements
#                                       binds:   the Python impl class
#       master/
#           arch.neuro                 ← imports `@brian/equations` + the
#                                        features it wants exposed; wires
#                                        them into synapses via `feature:`.
#
# Per CLAUDE.md §14: every equation here MUST be backed by a real
# implementation in neuroslm/modules/<name>.py and pinned by contract
# tests in tests/test_<name>.py. The formula string is the mathematical
# contract; the implementation must match.

# ─────────────────────────────────────────────────────────────────────
# Canonical synapse transmission (default for every edge unless a
# feature with `kind: "edge"` overrides it).
# ─────────────────────────────────────────────────────────────────────
export equation standard_synapse {
    params: [weight, x_pre, W],
    formula: "y = weight * (x_pre @ W)"
}

# Multiplicative modulation — e.g. dopamine/serotonin gain.
export equation multiplicative_modulation {
    params: [output, c, gain],
    formula: "y = output * (c * gain)"
}

# Additive offset — e.g. acetylcholine enhancing attention.
export equation additive_modulation {
    params: [output, c, gain],
    formula: "y = output + (c * gain)"
}

# ─────────────────────────────────────────────────────────────────────
# Feature-toggleable equations.
#
# Each equation below has:
#   - a per-feature `.neuro` file under features/ that wires it to a
#     Python impl class,
#   - a real PyTorch module under neuroslm/modules/,
#   - contract tests under tests/.
#
# Per CLAUDE.md §10, adding/changing an equation here is a research
# experiment: pair it with an Hxx hypothesis entry in docs/findings.md.
# ─────────────────────────────────────────────────────────────────────

# Mechanism 1: Hyperbolic (Poincaré-disc) multi-head attention.
#
# Ganea, Bécigneul, Hofmann — "Hyperbolic Neural Networks", NeurIPS 2018.
# Q,K live on the Poincaré ball with curvature c > 0; attention logits
# are negative hyperbolic distances scaled by sqrt(head_dim); V stays
# Euclidean (standard practice).
#
# Hypothesis: tree-shaped context (hierarchies, code AST, parse trees)
# benefits from a metric whose volume grows exponentially with radius.
#
# Implementation: neuroslm/modules/hyperbolic_attention.py
# Wiring:        @brian/features/hyperbolic_attention
# Docs:          docs/features/hyperbolic_attention.md
# Tests:         tests/test_hyperbolic_attention.py (18 contracts)
export equation hyperbolic_attention_eq {
    params: [d_model, n_heads, c],
    formula: "Attn(Q,K,V) = softmax(-d_hyp(expmap0(Q), expmap0(K)) / sqrt(d_head)) @ V"
}

# Mechanism 2: RoPE-on-a-Torus (multi-frequency rotary positional encoding).
#
# Su et al. — "RoFormer", Neurocomputing 568 (2024) — generalised to a
# product-of-circles manifold T^n = (S^1)^n. Each 2D embedding slice
# rotates by an angle whose period is drawn from a configurable schedule
# (geometric/linear/harmonic). Positions wrap modulo each slice's
# period — that's the torus part.
#
# Hypothesis: sequence position is cyclic at multiple scales (token,
# sentence, paragraph); per-slice periods capture this directly.
#
# Implementation: neuroslm/modules/rope_torus.py
# Wiring:        @brian/features/rope_torus
# Docs:          docs/features/rope_torus.md
# Tests:         tests/test_rope_torus.py (19 contracts)
export equation rope_torus_eq {
    params: [d_model, base, schedule],
    formula: "RoPE(x, p) = R(θ(p)) @ x where θ_j(p) = 2π·(p mod period_j)/period_j"
}

# Mechanism 3: Holographic Reduced Representations (HRR) memory.
#
# Plate (1995, 2003) — Compositional distributed representations via
# circular convolution binding. Memory M = Σ bind(k_i, v_i) is queried
# by unbinding: unbind(M, k_j) ≈ v_j + O(√(N/d)) noise.
#
# Hypothesis: content-addressable memory with O(d log d) cost beats
# softmax attention for long-range associative recall when the working-
# set size N << d.
#
# Implementation: neuroslm/modules/hrr_memory.py
# Wiring:        @brian/features/hrr_memory
# Docs:          docs/features/hrr_memory.md
# Tests:         tests/test_hrr_memory.py (16 contracts)
export equation hrr_memory_eq {
    params: [d_model, d_memory],
    formula: "retrieve(x) = IFFT(Σ_t FFT(k_t) * FFT(v_t) * conj(FFT(q_x)))"
}

# Mechanism 4: Predictive-coding residuals (Rao-Ballard 1999).
#
# Each layer predicts the layer below; only the residual ε = x - x̂
# propagates upward. State update: x ← x - α·ε (gradient on ½ε²).
#
# Hypothesis: explicit prediction errors make the trunk's information
# flow sparser and the loss signal closer to the surprise-driven
# updates predicted by free-energy formulations of cortex.
#
# Implementation: neuroslm/modules/predictive_coding_residual.py
# Wiring:        @brian/features/predictive_coding_residual
# Docs:          docs/features/predictive_coding_residual.md
# Tests:         tests/test_predictive_coding_residual.py (14 contracts)
export equation predictive_coding_residual_eq {
    params: [d_model, step_size],
    formula: "x' = x - α·(x - g(x))    where g is the top-down predictor"
}

# Mechanism 5: Surprise-gated Mixture-of-Experts.
#
# Standard MoE (Shazeer 2017) routes each token to top-k experts. Here
# k is dynamic per token: k(x) = round(k_min + (k_max-k_min)·σ(steep·(s-mid)))
# where s is the per-token surprise (gating entropy or supplied PC
# residual norm). High surprise → more compute; low surprise → cheaper.
#
# Hypothesis: matches free-energy principle (Friston 2010) — surprise
# drives compute allocation, like a soft early-exit / extra-think knob.
#
# Implementation: neuroslm/modules/surprise_gated_moe.py
# Wiring:        @brian/features/surprise_gated_moe
# Docs:          docs/features/surprise_gated_moe.md
# Tests:         tests/test_surprise_gated_moe.py (20 contracts)
export equation surprise_gated_moe_eq {
    params: [d_model, n_experts, k_min, k_max],
    formula: "MoE(x, s) = Σ_e top_w_e(x, k(s)) · expert_e(x)"
}
