# Stage 1 — Thalamic relay (bowtie bottleneck entry)
#
# Gated dynamics: ReLU input modulated by a learnable scalar gate. The
# gate parameter (zero-initialised) is the sigmoid-bounded "openness" of
# the relay. With gate=0, output is zero — nothing passes through.

export population thalamus {
    count: 256,
    dynamics: "gated",
    equation: "y = ReLU(x) * sigmoid(gate)",
    timescale: 0.01,
    capacity: 1.0
}
