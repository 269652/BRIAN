# Qwen2.5-0.5B — THSD cellular sheaf (trivial H¹, Qwen2 family)
#
# THSD framing: H¹ = 0 — GQA + RoPE like LLaMA family. Distinguishing
# features: large RoPE base (1M, YaRN-extended context), qkv_bias=true,
# large vocab (151936), untied embeddings.
#
# Reference: Qwen Team (Alibaba DAMO, 2024) Qwen2.5 Technical Report
# HF model ID: Qwen/Qwen2.5-0.5B

import { grouped_query_attention, rope_attention } from "@lib/primitives/attention"
import { swiglu_ffn } from "@lib/primitives/feedforward"
import { rms_norm } from "@lib/primitives/normalization"

model {
    weights: "hf:Qwen/Qwen2.5-0.5B"

    sheaf {
        dim: 896, depth: 24, heads: 14, kv_heads: 2, context: 32768, vocab: 151936

        embed {
            tokens:   learned
            position: none    # positional encoding in C¹ via rope_attention
        }

        coboundary {
            equation: grouped_query_attention   # GQA: 2 KV heads shared across 14 Q heads
            equation: rope_attention            # RoPE with YaRN-extended base
            qkv_bias: true                      # Qwen2-specific: bias on q/k/v projections
            bias: false                         # no bias on o_proj
            rope { base: 1000000 }              # 1M base for long-context (YaRN)
        }

        transition {
            equation: swiglu_ffn               # silu(gate·x) ⊙ up(x) → down
            ff_mult: 3.5
        }

        norm { equation: rms_norm, placement: pre, eps: 1e-6 }
        output { tie_embed: true }
    }
}
