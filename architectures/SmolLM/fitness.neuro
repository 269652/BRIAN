# -*- coding: utf-8 -*-
# RCC Bowtie Fitness Configuration
# Multi-objective optimization targets for evolutionary training

fitness {
    # Fitness objectives — minimize OOD PPL, maximize Phi, reduce gap ratio
    objectives: [
        {
            name: "minimize_ood_ppl",
            metric: "ood_ppl",
            direction: "minimize",
            weight: 0.50,
            target: 175.0
        },
        {
            name: "maximize_phi",
            metric: "phi",
            direction: "maximize",
            weight: 0.30,
            target: 0.18
        },
        {
            name: "minimize_gap_ratio",
            metric: "gap_ratio",
            direction: "minimize",
            weight: 0.20,
            target: 2.0
        }
    ],

    # Adaptive fitness parameters — enable self-improving objectives
    adaptation: {
        enabled: true,
        mutation_rate: 0.01,           # 1% chance of fitness mutation per step
        target_adjustment_rate: 0.001, # Tighten targets adaptively
        weight_adjustment_rate: 0.01   # Reweight objectives based on progress
    }
}
