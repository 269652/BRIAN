# -*- coding: utf-8 -*-
# GPT-2 124M -- THSD cellular sheaf definition (trivial H1)
#
# kind=gpt2: learned positional embeddings, LayerNorm, fused QKV (c_attn),
# GELU (tanh-approximate), bias everywhere, weight-tied lm_head.
#
# THSD framing: trivial H1 sheaf -- no conservation laws, no THSD mechanisms.
# Every self-attention block is a coboundary operator delta: C0(F) -> C1(F).
#
# Load HF weights:
#   from neuroslm.models.gpt2 import GPT2Model, hf_to_model_state_dict
#   from neuroslm.dsl.model_spec import parse_model_block
#   spec = parse_model_block(open("architectures/gpt2/arch.neuro").read())
#   model = GPT2Model(spec)
#
# Reference: Radford et al. 2019 "Language Models are Unsupervised Multitask Learners"
# HF model ID: openai-community/gpt2

model {
    kind: gpt2
    weights: "hf:openai-community/gpt2"
    sheaf {
        dim: 768
        depth: 12
        heads: 12
        kv_heads: 12
        context: 1024
        vocab: 50257
        pos: learned
        rope_base: 10000
        ff_mult: 4.0
        ff_act: gelu
        norm: layernorm
        norm_eps: 1e-5
        tie_embed: true
        bias: true
    }
}
