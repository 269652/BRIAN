# GPT-2 124M — THSD cellular sheaf (trivial H¹)
#
# THSD framing: H¹ = 0 — standard MHA coboundary with no phase structure.
# Stalk dim = 768; coboundary = fused-QKV MHA; transition = GELU MLP.
#
# Reference: Radford et al. 2019 "Language Models are Unsupervised Multitask Learners"
# HF model ID: openai-community/gpt2

import { multi_head_attention } from "@lib/primitives/attention"
import { learned_position_encoding } from "@lib/primitives/attention"
import { gelu_ffn } from "@lib/primitives/feedforward"
import { layer_norm } from "@lib/primitives/normalization"

model {
    weights: "hf:openai-community/gpt2"

    sheaf {
        dim: 768, depth: 12, heads: 12, context: 1024, vocab: 50257

        embed {
            tokens:   learned
            position: learned    # learned_position_encoding in C⁰
            equation: learned_position_encoding
        }

        coboundary {
            equation: multi_head_attention   # fused QKV (Conv1D c_attn), no RoPE
            bias: true                       # bias in c_attn and c_proj
        }

        transition {
            equation: gelu_ffn               # W_2 GELU(W_1 x + b) + b
            ff_mult: 4.0
            bias: true
        }

        norm { equation: layer_norm, placement: pre, eps: 1e-5 }
        output { tie_embed: true }
    }
}
