# -*- coding: utf-8 -*-
# Shared equation library — reusable across every BRIAN architecture.
#
# Resolution: importable as `@brian/equations` from any arch.neuro.
# Anchored at <repo>/architectures/lib/equations.neuro by the @brian/
# prefix in neuroslm/dsl/multifile.py:PathResolver.
#
# Layout convention:
#
#   architectures/
#       lib/
#           equations.neuro            ← this file (declarations only)
#           features/
#               <name>.neuro           ← one file per toggleable mechanism
#                                       declares: feature <name> { ... }
#                                       imports: the equation it implements
#                                       binds:   the Python impl class
#       master/
#           arch.neuro                 ← imports `@brian/equations` + the
#                                        features it wants exposed; wires
#                                        them into synapses via `feature:`.
#
# Per CLAUDE.md §14: every equation here MUST be backed by a real
# implementation in neuroslm/modules/<name>.py and pinned by contract
# tests in tests/test_<name>.py. The formula string is the mathematical
# contract; the implementation must match.

# ─────────────────────────────────────────────────────────────────────
# Canonical synapse transmission (default for every edge unless a
# feature with `kind: "edge"` overrides it).
# ─────────────────────────────────────────────────────────────────────
export equation standard_synapse {
    params: [weight, x_pre, W],
    formula: "y = weight * (x_pre @ W)"
}

# Multiplicative modulation — e.g. dopamine/serotonin gain.
export equation multiplicative_modulation {
    params: [output, c, gain],
    formula: "y = output * (c * gain)"
}

# Additive offset — e.g. acetylcholine enhancing attention.
export equation additive_modulation {
    params: [output, c, gain],
    formula: "y = output + (c * gain)"
}

# ─────────────────────────────────────────────────────────────────────
# Feature-toggleable equations.
#
# Each equation below has:
#   - a per-feature `.neuro` file under features/ that wires it to a
#     Python impl class,
#   - a real PyTorch module under neuroslm/modules/,
#   - contract tests under tests/.
#
# Per CLAUDE.md §10, adding/changing an equation here is a research
# experiment: pair it with an Hxx hypothesis entry in docs/findings.md.
# ─────────────────────────────────────────────────────────────────────

# Mechanism 1: Hyperbolic (Poincaré-disc) multi-head attention.
#
# Ganea, Bécigneul, Hofmann — "Hyperbolic Neural Networks", NeurIPS 2018.
# Q,K live on the Poincaré ball with curvature c > 0; attention logits
# are negative hyperbolic distances scaled by sqrt(head_dim); V stays
# Euclidean (standard practice).
#
# Hypothesis: tree-shaped context (hierarchies, code AST, parse trees)
# benefits from a metric whose volume grows exponentially with radius.
#
# Implementation: neuroslm/modules/hyperbolic_attention.py
# Wiring:        @brian/features/hyperbolic_attention
# Docs:          docs/features/hyperbolic_attention.md
# Tests:         tests/test_hyperbolic_attention.py (18 contracts)
export equation hyperbolic_attention_eq {
    params: [d_model, n_heads, c],
    formula: "Attn(Q,K,V) = softmax(-d_hyp(expmap0(Q), expmap0(K)) / sqrt(d_head)) @ V"
}
