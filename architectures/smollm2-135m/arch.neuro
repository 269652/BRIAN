# SmolLM2-135M — THSD cellular sheaf (trivial H¹, LLaMA family)
#
# THSD framing: H¹ = 0 — GQA + RoPE gives phase-structured C¹ but no
# conservation law. SwiGLU gating provides non-linearity with learnable routing.
#
# Reference: Allal et al. (HuggingFace, 2025) SmolLM2
# HF model ID: HuggingFaceTB/SmolLM2-135M

import { grouped_query_attention, rope_attention } from "@lib/primitives/attention"
import { swiglu_ffn } from "@lib/primitives/feedforward"
import { rms_norm } from "@lib/primitives/normalization"

model {
    weights: "hf:HuggingFaceTB/SmolLM2-135M"

    sheaf {
        dim: 576, depth: 30, heads: 9, kv_heads: 3, context: 2048, vocab: 49152

        embed {
            tokens:   learned
            position: none    # positional encoding is in C¹ via rope_attention
        }

        coboundary {
            equation: grouped_query_attention   # GQA: 3 KV heads shared across 9 Q heads
            equation: rope_attention            # RoPE phase encoding in C¹
            rope { base: 10000 }
        }

        transition {
            equation: swiglu_ffn               # silu(gate·x) ⊙ up(x) → down
            ff_mult: 3.5
        }

        norm { equation: rms_norm, placement: pre, eps: 1e-5 }
        output { tie_embed: true }
    }
}
