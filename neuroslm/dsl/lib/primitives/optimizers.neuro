# ═══════════════════════════════════════════════════════════════════════

export comparison optimizer_choice {
    dimensions: ["Memory", "Speed", "Quality", "Use Case"]
    
    rows: {
        SGD_Momentum: [
            "O(P)",
            "Fastest",
            "Good (convex)",
            "Computer vision (ResNets)"
        ]
        
        RMSprop: [
            "O(P)",
            "Fast",
            "Good (RNNs)",
            "Legacy (RNNs, RL)"
        ]
        
        Adam: [
            "O(2P)",
            "Medium",
            "Good",
            "General-purpose"
        ]
        
        AdamW: [
            "O(2P)",
            "Medium",
            "Best (LLMs)",
            "DEFAULT for transformers"
        ]
        
        Adafactor: [
            "O(√P)",
            "Medium",
            "Good",
            "Memory-constrained (T5)"
        ]
        
        Lion: [
            "O(P)",
            "Fast",
            "Best? (new)",
            "Vision, early LLM results"
        ]
    }
    
    recommendation: """
        For transformers: AdamW with cosine decay + warmup
        
        Typical config:
            optimizer: AdamW(β1=0.9, β2=0.95, weight_decay=0.1)
            lr_schedule: cosine_with_warmup(max=3e-4, min=3e-5, warmup=2000)
            grad_clip: 1.0
    """
}
