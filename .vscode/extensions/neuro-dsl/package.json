{
  "name": "neuro-dsl",
  "displayName": "NeuroSLM DSL",
  "description": "Syntax highlighting, semantic linting, and autocomplete for .neuro architecture files",
  "version": "0.2.0",
  "publisher": "neuroslm",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": ["Programming Languages", "Linters"],
  "contributes": {
    "languages": [
      {
        "id": "neuro",
        "aliases": ["NeuroSLM DSL", "neuro"],
        "extensions": [".neuro"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "neuro",
        "scopeName": "source.neuro",
        "path": "./syntaxes/neuro.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "neuro-dsl.lint",
        "title": "NeuroSLM: Lint current .neuro file",
        "when": "editorLangId == neuro"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:neuro"
  ],
  "main": "./extension.js"
}
