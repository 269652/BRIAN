# Checkpoints / model weights
# LFS-tracked checkpoints are allowed

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Data files / downloads
data/
datasets/
*.csv
*.tar.gz
*.zip

# Jupyter
.ipynb_checkpoints/
*.ipynb
!colab_run.ipynb
!colab_test.ipynb

# Editor/project files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Logs and runtime
*.log
training.err
training.log
# Specific logs/ subdirs that are noise; logs/vast and logs/analyzed
# are intentionally NOT in the blacklist — see whitelist below.
logs/live/
logs/tmp/
logs/runs/
logs/cache/
# Whitelist raw vast.ai stdout captures and their LLM-produced analyses.
# These are committed evidence and override the *.log catch-all above.
!logs/vast/*.log
!logs/analyzed/*.md
!logs/analyzed/INSTRUCTIONS.md

# Testing and packaging
pip-wheel-metadata/
.pytest_cache/

# Temp
tmp/
temp/
.cache/


# Local secrets — never commit
.env

# DNA compilation artifacts
dna/
architectures/evol/
