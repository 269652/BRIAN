# Checkpoints / model weights
# LFS-tracked checkpoints are allowed
# Local inference checkpoints (downloaded by `brian checkpoints download`)
checkpoints/

# .brian/ runtime artefacts (job registry, ckpt pointer, best_run pointer)
# The directory itself is project-local state, not source of truth.
.brian/jobs/

# Python caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Data files / downloads
data/
datasets/
*.csv
*.tar.gz
*.zip

# Jupyter
.ipynb_checkpoints/
*.ipynb
!colab_run.ipynb
!colab_test.ipynb

# Editor/project files
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db

# Logs and runtime
*.log
training.err
training.log
# Specific logs/ subdirs that are noise; logs/vast / logs/analyzed /
# logs/<per-run-folder>/ are intentionally NOT in the blacklist — see
# whitelist below.
logs/live/
logs/tmp/
logs/runs/
logs/cache/
# Whitelist raw vast.ai stdout captures and their LLM-produced analyses.
# These are committed evidence and override the *.log catch-all above.
#
# Patterns (2026-06-16 refactor):
#
#   ``!logs/vast/**/*.log``           legacy flat layout (pre-2026-06-15)
#   ``!logs/????????/*/*.log``        NEW: logs/<YYYYMMDD>/<arch>/<HHMMSS>_<start>_<end>.log
#                                     Each .log file directly in arch folders
#   ``!logs/????????/*/*/train.log``  legacy 3-level: logs/<date>/<arch>/<folder>/train.log
#                                     (transition period support)
#   ``!logs/analyzed/...``            LLM analyses
!logs/vast/**/*.log
!logs/????????/*/*.log
!logs/????????/*/*/train.log
!logs/analyzed/*.md
!logs/analyzed/INSTRUCTIONS.md

# Explicitly block old flat-format per-run dirs (YYYYMMDD-HHMMSS_arch_sha/)
# and bare "arch" 3-level dirs. These were produced by older log_pusher.sh
# versions that recreated the folder on each push (sha proliferation bug).
# The rules above already exclude them via the exact-3-segment whitelist,
# but these explicit blocks prevent any accidental re-inclusion.
logs/????????-*/
logs/????????/arch/

# Testing and packaging
pip-wheel-metadata/
.pytest_cache/

# Temp
tmp/
temp/
.cache/


# Local secrets — never commit
.env

# DNA compilation artifacts (intermediate snapshots, patches, heatmaps).
# The canonical evolved genome dna/evol/arch.dna IS source-of-truth and
# is whitelisted below — without it, Colab/vast clones can't train in
# DNA mode (brian.toml points at this path; train_dsl.py refuses to
# start when missing). See README "DNA mode" and tests/test_project_config.py.
#
# Pattern shape: ignore directory *contents* (not the dir itself) so the
# re-include rule for arch.dna can take effect — git can't un-ignore a
# file whose parent directory has been ignored wholesale.
#
# 2026-06-15: extended the whitelist to ANY branch's arch.dna
# (dna/{branch}/arch.dna) after instance 41048619 crashed with
# "✗ missing ./dna/master/arch.dna" — the pre-deploy hook silently
# falsely-reported "no roundtrip diff" because `dna/*` was dropping
# the file before `git add -A` could stage it. Locked by
# tests/test_deploy_failure_safety.py::TestPerBranchDnaIsNotGitignored.
#
# Heatmaps written by the evolution loop live in results/heatmaps/
# (HeatmapPublisher default) or in <checkpoint_dir>/live_heatmap.json
# (runtime artifact), so they don't need allowlisting under dna/.
dna/*
!dna/*/
dna/*/*
!dna/*/arch.dna
architectures/evol/

# Lean / Lake build artifacts (lean/Brian/** source IS tracked)
lean/.lake/
lean/build/
*.olean
*.olean.trace
*.ilean
*.hash

# Ad-hoc NFG demo renders (large PNGs from
# `brian nfg render --out ...`). `.neuro/` is intentionally tracked
# (sample_heatmap.json etc.) — only top-level demo PNGs are noise.
/nfg_rcc_*.png
/results/nfg_*.png

# Run workspace — `prepare_run_workspace()` unpacks the current DNA /
# arch source here on every `brian train --dna=... | --arch=...`
# invocation. Pure runtime cache; rebuilt fresh every call.
.neuro/arch/temp/